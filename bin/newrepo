#!/usr/bin/env bash
# newrepo <git_url> [optional_repo_name]
# Clones a repo into dev/<repo_name>/main and sets it up for worktrees.

set -euo pipefail

if [ $# -lt 1 ]; then
  echo "Usage: newrepo <git_url> [repo_name] [main_branch]"
  exit 1
fi

REPO_URL="$1"
REPO_NAME="${2:-$(basename -s .git "$REPO_URL")}"
MAIN_BRANCH="${3:-main}"
DEST="${PWD}/${REPO_NAME}"

mkdir -p "$DEST"
cd "$DEST"
echo "→ Created directory ${DEST} ..."

# Bare clone setup for worktrees
echo "→ Cloning ${REPO_URL} (bare) into ${DEST}/.bare ..."
git clone --bare -c remote.origin.fetch="+refs/heads/*:refs/remotes/origin/*" "$REPO_URL" .bare
echo "gitdir: ./.bare" > .git

cd .bare

# Fetch latest branches and tags
git fetch --all --prune --tags

# Check out main branch as a worktree
cd "$DEST"
git worktree add "$MAIN_BRANCH" "$MAIN_BRANCH"

echo "✅ Repo ready: ${DEST}/${MAIN_BRANCH}"
echo "To create a new worktree:"
echo "  cd ${DEST}/${MAIN_BRANCH}"
echo "  gwtc feature-branch-name"
